{
  "name": "online-auction-management",
  "version": "1.0.0",
  "description": "Online Auction Management System with Angular 20 and Node.js 24",
  "main": "server/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && ng serve",
    "build": "cd client && ng build",
    "build:prod": "cd client && ng build --configuration production",
    "install-client": "cd client && npm install",
    "install-server": "npm install",
    "install-all": "npm run install-server && npm run install-client",
    "create-angular": "npx @angular/cli@20 new client --routing --style=scss --skip-git --package-manager=npm"
  },
  "dependencies": {
    "express": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "mongoose": "^8.7.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.8.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "concurrently": "^9.0.1"
  },
  "keywords": ["auction", "management", "express", "angular", "node24"],
  "author": "Your Name",
  "license": "MIT"
}